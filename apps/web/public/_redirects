# Redirect old vendor paths to new clean dashboard paths
/vendor/*    /:splat    301

# SPA Fallback for Dashboard and Admin routes
/dashboard/*  /dashboard/index.html  200
/listings/*   /listings/index.html   200
/leads/*      /leads/index.html      200
/subscription/* /subscription/index.html 200
/settings/*   /settings/index.html   200
/admin/*     /admin/:splat.html     200

# Category and City slug fallbacks - ensure dynamic list pages work on refresh
/categories/*  /categories/template/index.html  200
/cities/*      /cities/template/index.html      200

# Business slug fallback - ensure dynamic business pages work on refresh
/business/*  /business/template/index.html  200

# Generic fallback to index.html for unknown routes
/*  /index.html  200
